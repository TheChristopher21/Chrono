<resources>
    <style name="Theme.Chrono" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/chrono_background</item>
        <item name="android:navigationBarColor">@color/chrono_background</item>
        <item name="android:windowNoTitle">true</item>
