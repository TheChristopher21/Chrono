diff --git a/Chrono-frontend/src/test/NotificationContext.test.jsx b/Chrono-frontend/src/test/NotificationContext.test.jsx
new file mode 100644
index 0000000..7efc9d0
--- /dev/null
+++ b/Chrono-frontend/src/test/NotificationContext.test.jsx
@@ -0,0 +1,60 @@
+import React from 'react';
+import { fireEvent, render, screen } from '@testing-library/react';
+import { describe, expect, it } from 'vitest';
+
+import { NotificationProvider, useNotification } from '../context/NotificationContext.jsx';
+import { LanguageProvider } from '../context/LanguageContext.jsx';
+
+function NotificationHarness({ mode }) {
+    const { notify } = useNotification();
+
+    return (
+        <button
+            type="button"
+            onClick={() => {
+                if (mode === 'legacy-warning') {
+                    notify('Bitte pruefen', 'warning');
+                    return;
+                }
+
+                notify({ message: 'Fehler beim Speichern', type: 'error' });
+            }}
+        >
+            Toast ausloesen
+        </button>
+    );
+}
+
+describe('NotificationContext', () => {
+    it('supports the legacy notify(message, type) signature', async () => {
+        render(
+            <LanguageProvider>
+                <NotificationProvider>
+                    <NotificationHarness mode="legacy-warning" />
+                </NotificationProvider>
+            </LanguageProvider>
+        );
+
+        fireEvent.click(screen.getByRole('button', { name: 'Toast ausloesen' }));
+
+        const toast = await screen.findByText('Bitte pruefen');
+        expect(toast).toBeInTheDocument();
+        expect(toast.closest('.notification-toast')).toHaveClass('warn');
+    });
+
+    it('keeps object-based notifications working', async () => {
+        render(
+            <LanguageProvider>
+                <NotificationProvider>
+                    <NotificationHarness mode="object-error" />
+                </NotificationProvider>
+            </LanguageProvider>
+        );
+
+        fireEvent.click(screen.getByRole('button', { name: 'Toast ausloesen' }));
+
+        const toast = await screen.findByText('Fehler beim Speichern');
+        expect(toast).toBeInTheDocument();
+        expect(toast.closest('.notification-toast')).toHaveClass('error');
+    });
+});
diff --git a/Chrono-frontend/src/test/projectSelection.test.js b/Chrono-frontend/src/test/projectSelection.test.js
new file mode 100644
index 0000000..eb46bf2
--- /dev/null
+++ b/Chrono-frontend/src/test/projectSelection.test.js
@@ -0,0 +1,33 @@
+import { describe, expect, it } from 'vitest';
+
+import {
+    filterProjectsByCustomer,
+    getProjectCustomerId,
+    projectMatchesCustomer,
+} from '../utils/projectSelection.js';
+
+const projects = [
+    { id: 1, name: 'Alpha', customerId: 10 },
+    { id: 2, name: 'Beta', customer: { id: 20 } },
+    { id: 3, name: 'Gamma' },
+];
+
+describe('projectSelection helpers', () => {
+    it('reads customer ids from flat and nested project shapes', () => {
+        expect(getProjectCustomerId(projects[0])).toBe('10');
+        expect(getProjectCustomerId(projects[1])).toBe('20');
+        expect(getProjectCustomerId(projects[2])).toBe('');
+    });
+
+    it('filters projects only when a customer is selected', () => {
+        expect(filterProjectsByCustomer(projects, '')).toHaveLength(3);
+        expect(filterProjectsByCustomer(projects, 10)).toEqual([projects[0]]);
+        expect(filterProjectsByCustomer(projects, '20')).toEqual([projects[1]]);
+    });
+
+    it('treats an empty customer selection as compatible', () => {
+        expect(projectMatchesCustomer(projects[0], '')).toBe(true);
+        expect(projectMatchesCustomer(projects[0], 10)).toBe(true);
+        expect(projectMatchesCustomer(projects[0], 20)).toBe(false);
+    });
+});
diff --git a/Chrono-frontend/src/utils/projectSelection.js b/Chrono-frontend/src/utils/projectSelection.js
new file mode 100644
index 0000000..c8a7b01
--- /dev/null
+++ b/Chrono-frontend/src/utils/projectSelection.js
@@ -0,0 +1,33 @@
+export const normalizeSelectionId = (value) => {
+    if (value === null || value === undefined || value === '') {
+        return '';
+    }
+
+    return String(value);
+};
+
+export const getProjectCustomerId = (project) =>
+    normalizeSelectionId(project?.customer?.id ?? project?.customerId ?? '');
+
+export const filterProjectsByCustomer = (projects = [], customerId) => {
+    const normalizedCustomerId = normalizeSelectionId(customerId);
+    const safeProjects = Array.isArray(projects) ? projects : [];
+
+    if (!normalizedCustomerId) {
+        return safeProjects;
+    }
+
+    return safeProjects.filter(
+        (project) => getProjectCustomerId(project) === normalizedCustomerId
+    );
+};
+
+export const projectMatchesCustomer = (project, customerId) => {
+    const normalizedCustomerId = normalizeSelectionId(customerId);
+
+    if (!normalizedCustomerId) {
+        return true;
+    }
+
+    return getProjectCustomerId(project) === normalizedCustomerId;
+};
